# Secrets
.env
.runpod_pod.json
.ssh_pubkey

# Python
.venv/
.venv-labelstudio/
__pycache__/
*.pyc

# Data: default to ignored, carve out small text/label files.
data/*
!data/README.md
!data/manifests/
!data/ngs/
!data/labels/
!data/training/

# Manifests + NGS ground truth are fully tracked.
!data/manifests/*
!data/ngs/*

# Hand-labeled label files we keep (label JSONs / YOLO txts / config XMLs).
!data/labels/player_detection/
!data/labels/player_detection/export_final/
!data/labels/player_detection/export_final/labels/
!data/labels/player_detection/export_final/classes.txt
!data/labels/player_detection/labels/
!data/labels/field_keypoints/
!data/labels/field_keypoints/labeling_config.xml
!data/labels/field_keypoints/field_keypoints_hand_labeled.json
!data/labels/field_keypoints/al_round*/
!data/labels/field_keypoints/al_round*/*.json
!data/labels/line_masks/manifest.json

# Bulk image folders under labels/ — large, regeneratable, ignored.
data/labels/player_detection/images/
data/labels/view_classifier/
data/labels/field_keypoints/synthetic/
data/labels/field_keypoints/annotation_images/
data/labels/field_keypoints/train/
data/labels/field_keypoints/valid/
data/labels/field_keypoints/al_round*/candidates/
data/labels/field_keypoints/al_round*/images/
data/labels/line_masks/

# All generated training datasets — regeneratable, ignored.
data/training/

# Videos
videos/
*.mp4
!videos/
!videos/games/
!videos/clips/

# Model weights
*.pt
*.pth
models/*
!models/README.md

# Output: track only NGS comparison CSV/TXT.
output/*
!output/ngs_compare/
output/ngs_compare/*
!output/ngs_compare/*.csv
!output/ngs_compare/*.txt

# Build/scratch
*.tar
*.log


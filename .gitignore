# Secrets
.env
.runpod_pod.json
.ssh_pubkey

# Python
.venv/
.venv-labelstudio/
__pycache__/
*.pyc

# Data (large video/clip files)
data/
videos/
*.mp4
# But track the directory structure (not the video/clip files themselves)
!videos/
!videos/games/
!videos/clips/

# Model weights (large binary files)
*.pt
models/

# But do track annotations (small text files, hard to recreate)
!data/
!data/annotations/
!data/annotations/export_final/
!data/annotations/export_final/labels/
!data/annotations/export_final/classes.txt
!data/annotations/200_frames_hand_labeled.zip
!data/annotations/labels/

# Training images (large binary files, regeneratable)
data/annotations/images/
data/view_classifier/

# Output (generated images, tracking results)
output/


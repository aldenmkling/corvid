# Secrets
.env
.runpod_pod.json
.ssh_pubkey

# Python
.venv/
.venv-labelstudio/
__pycache__/
*.pyc

# Data (large video/clip files)
data/
videos/
*.mp4
# But track the directory structure (not the video/clip files themselves)
!videos/
!videos/games/
!videos/clips/

# Model weights (large binary files)
*.pt
models/

# But do track annotations (small text files, hard to recreate)
!data/
!data/annotations/
!data/annotations/export_final/
!data/annotations/export_final/labels/
!data/annotations/export_final/classes.txt
!data/annotations/labels/
!data/field_keypoints/
!data/field_keypoints/labeling_config.xml

# Training data (large binary files, regeneratable)
data/annotations/images/
data/view_classifier/
data/player_detection/
data/field_keypoints/synthetic/
data/field_keypoints/annotation_images/
data/field_keypoints/train/
data/field_keypoints/valid/
# AL rounds: track label JSONs + manifests, ignore the bulk JPEG folders
data/field_keypoints/al_round*/candidates/
data/field_keypoints/al_round*/images/
# Line-detection dataset (regeneratable from self_sup_pool_10k + review JSON)
data/line_detection/
data/line_detection_build.log
# Hash-only keypoint split (regeneratable from data/field_keypoints)
data/field_keypoints_hash_only/
# Hash mask round 3 (regeneratable from data/field_keypoints + line UNet)
data/hash_masks/
# Painted-number classifier crops (auto-mined from rectify pipeline)
data/number_classifier/
# Pseudo-labeled training pool (regeneratable via farm_pseudo_labels.py)
data/pseudo_labels/
data/pseudo_labels_crops/
# Unified mask training data (regeneratable via build_unified_mask_dataset.py)
data/unified_masks/

# Output (generated images, tracking results)
output/
# Track only the small NGS-comparison artifacts; ignore the big mp4s.
!output/ngs_compare/
!output/ngs_compare/*.csv
!output/ngs_compare/*.txt

# macOS
.DS_Store

# IDE
.vscode/
.idea/
.Rhistory

# Claude
.claude/

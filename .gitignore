# Secrets
.env
.runpod_pod.json
.ssh_pubkey

# Python
.venv/
.venv-labelstudio/
__pycache__/
*.pyc

# Data (large video/clip files)
data/
videos/
*.mp4
# But track the directory structure (not the video/clip files themselves)
!videos/
!videos/games/
!videos/clips/

# Model weights (large binary files)
*.pt
models/

# But do track annotations (small text files, hard to recreate)
!data/
!data/annotations/
!data/annotations/export_final/
!data/annotations/export_final/labels/
!data/annotations/export_final/classes.txt
!data/annotations/labels/
!data/field_keypoints/
!data/field_keypoints/labeling_config.xml

# Training data (large binary files, regeneratable)
data/annotations/images/
data/view_classifier/
data/player_detection/
data/field_keypoints/synthetic/
data/field_keypoints/annotation_images/
data/field_keypoints/train/
data/field_keypoints/valid/
# AL rounds: track label JSONs + manifests, ignore the bulk JPEG folders
data/field_keypoints/al_round*/candidates/
data/field_keypoints/al_round*/images/

# Output (generated images, tracking results)
output/

# macOS
.DS_Store

# IDE
.vscode/
.idea/
.Rhistory

# Claude
.claude/
